{
  "name": "project-finder",
  "version": "1.0.0",
  "description": "Quick project folder finder for network drives",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "dist": "npm run build && electron-builder",
    "test": "jest"
  },
  "build": {
    "appId": "com.bpa.project-finder",
    "productName": "Project Finder",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "electron": "^28.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@electron/rebuild": "^4.0.4",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "electron-builder": "^26.15.3",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
